{
  "rewrites": [
    { "source": "/_next/static/:path*",  "destination": "https://bhavana-client-dashboard.vercel.app/_next/static/:path*" },
    { "source": "/_next/image",          "destination": "https://bhavana-client-dashboard.vercel.app/_next/image" },
    { "source": "/api/auth/:path*",      "destination": "https://bhavana-client-dashboard.vercel.app/api/auth/:path*" },
    { "source": "/login",                "destination": "https://bhavana-client-dashboard.vercel.app/login" },
    { "source": "/gallery",              "destination": "https://bhavana-client-dashboard.vercel.app/gallery" },
    { "source": "/gallery/:path*",       "destination": "https://bhavana-client-dashboard.vercel.app/gallery/:path*" },
    { "source": "/admin",                "destination": "https://bhavana-client-dashboard.vercel.app/admin" },
    { "source": "/admin/:path*",         "destination": "https://bhavana-client-dashboard.vercel.app/admin/:path*" }
  ]
}
