# =============================================================================
# BHAVANA STUDIO - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://bhavana:bhavana_secret@localhost:5432/bhavana_studio
POSTGRES_USER=bhavana
POSTGRES_PASSWORD=bhavana_secret
POSTGRES_DB=bhavana_studio

# --- API ---
API_PORT=4000
API_URL=http://localhost:4000
NODE_ENV=development

# --- JWT / Auth ---
NEXTAUTH_SECRET=your-super-secret-nextauth-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3001
JWT_SECRET=your-jwt-secret-at-least-32-chars

# --- S3 / Object Storage ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=bhavana-photos
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/bhavana-photos

# --- Image Processing ---
IMAGE_PROCESSING_URL=http://localhost:5000
THUMBNAIL_WIDTH=400
THUMBNAIL_HEIGHT=300
PREVIEW_WIDTH=1200
PREVIEW_HEIGHT=900

# --- Admin ---
ADMIN_EMAIL=admin@bhavanastudio.com
ADMIN_PASSWORD=Admin@12345

# --- Web (Public Site) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Client Dashboard ---
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001
NEXT_PUBLIC_DASHBOARD_API_URL=http://localhost:4000

# --- Redis (for sessions / rate limiting) ---
REDIS_URL=redis://localhost:6379
