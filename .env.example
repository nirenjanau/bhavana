# =============================================================================
# BHAVANA STUDIO - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://bhavana:bhavana_secret@localhost:5432/bhavana_studio
POSTGRES_USER=bhavana
POSTGRES_PASSWORD=bhavana_secret
POSTGRES_DB=bhavana_studio

# --- API ---
API_PORT=4000
API_URL=http://localhost:4000
NODE_ENV=development

# --- JWT / Auth ---
NEXTAUTH_SECRET=your-super-secret-nextauth-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3001
JWT_SECRET=your-jwt-secret-at-least-32-chars

# --- S3 / Object Storage ---
#
# Local dev: MinIO (docker-compose). Keep as-is.
#
# Production options (drop-in — all S3-compatible, no code changes):
#
#   1) Cloudflare R2  — RECOMMENDED
#        • $0.015/GB/mo, ZERO egress. 2 TB ≈ $30/mo total.
#        • S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
#        • S3_REGION=auto
#        • Public URL via a custom domain bound to the bucket.
#
#   2) Backblaze B2
#        • $0.006/GB/mo + $0.01/GB egress. Cheapest at rest.
#        • S3_ENDPOINT=https://s3.<region>.backblazeb2.com
#
#   3) Wasabi  — flat $6.99/TB/mo, no egress fees, 90-day min retention.
#
#   4) Self-hosted MinIO on a VPS w/ a 4TB disk (Hetzner ≈ €30/mo).
#
# Photo-size rule of thumb (lossless WebP originals, as used by this app):
#   ~10 MB avg per frame → 100 photos/GB → 1 TB ≈ 100,000 photos
# A typical wedding (1,500–3,000 frames) uses 15–30 GB. The default per-client
# quota is 30 GB; override per client in the admin client workspace.
#
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=bhavana-photos
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/bhavana-photos

# --- Image Processing ---
IMAGE_PROCESSING_URL=http://localhost:5000
THUMBNAIL_WIDTH=400
THUMBNAIL_HEIGHT=300
PREVIEW_WIDTH=1200
PREVIEW_HEIGHT=900

# --- Admin ---
ADMIN_EMAIL=admin@bhavanastudio.com
ADMIN_PASSWORD=Admin@12345

# --- Web (Public Site) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Client Dashboard ---
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001
NEXT_PUBLIC_DASHBOARD_API_URL=http://localhost:4000

# --- Redis (for sessions / rate limiting) ---
REDIS_URL=redis://localhost:6379
